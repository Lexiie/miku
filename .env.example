# =============================================================
# Nosana x ElizaOS Agent Challenge — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
# cp .env.example .env

# -------------------------------------------------------------
# LLM Configuration — Gemini via OpenAI-compatible endpoint
# -------------------------------------------------------------
# Create a Gemini API key in Google AI Studio or Google Cloud,
# then point ElizaOS at the OpenAI-compatible Gemini endpoint.

OPENAI_API_KEY=your_gemini_api_key
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
OPENAI_SMALL_MODEL=gemini-2.5-flash
OPENAI_LARGE_MODEL=gemini-2.5-flash
OPENAI_EMBEDDING_MODEL=gemini-embedding-001
OPENAI_EMBEDDING_DIMENSIONS=1536

# -------------------------------------------------------------
# Option B: Local development with Ollama (optional)
# -------------------------------------------------------------
# Install Ollama: https://ollama.com/download
# Then run: ollama pull qwen3.5:27b && ollama serve
#
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_SMALL_MODEL=qwen3.5:27b
# OPENAI_LARGE_MODEL=qwen3.5:27b

# -------------------------------------------------------------
# Agent Server Configuration
# -------------------------------------------------------------
SERVER_PORT=3000

# -------------------------------------------------------------
# Database (SQLite — sufficient for development)
# -------------------------------------------------------------
# Default: ./data/db.sqlite (created automatically)
# For production, consider a persistent storage solution.
# SQLITE_DATA_DIR=./data

# -------------------------------------------------------------
# Optional: Social Integrations (add plugins as needed)
# -------------------------------------------------------------
# Telegram bot — https://core.telegram.org/bots#creating-a-new-bot
# TELEGRAM_BOT_TOKEN=

# Discord bot — https://discord.com/developers/applications
# DISCORD_API_TOKEN=

# Twitter/X — https://developer.twitter.com
# TWITTER_USERNAME=
# TWITTER_PASSWORD=
# TWITTER_EMAIL=
